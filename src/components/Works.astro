---
import { profile } from '@/content/profile';
import titleImage from '../../assets/LockKnock/Tittle.png';
import coverHorizontal from '../../assets/LockKnock/Cover_Horizontal.jpg';
import coverVertical from '../../assets/LockKnock/Cover_Vertical.png';
import gameplayImage from '../../assets/LockKnock/Lockknock_Screenshot_1.png';
import menuImage from '../../assets/LockKnock/Lockknock_Screenshot_2.png';
import lanternCoverImage from '../../assets/LockKnock/Lockknock_Screenshot_3.png';
import seerAssistantScreenshot from '../../assets/SeerAssistant/SeerAssistant_Screenshot.png';

const seerAssistant = profile.works.find((work) => work.id === 'seer-assistant')!;
const otherWorks = profile.works.filter((work) => work.id !== 'seer-assistant');
---

<section id="works" class="works-slide slide" data-nav-surface="ember" aria-label="作品">
  <div class="work-carousel" data-work-carousel tabindex="0">
    <div class="work-track">
      <article class="work-panel lock-knock-panel is-active" data-work-panel data-nav-surface="ember" aria-hidden="false">
        <div class="firelight" aria-hidden="true"></div>
        <div class="embers" aria-hidden="true">
          {Array.from({ length: 18 }, (_, index) => <i style={`--x:${(index * 19 + 7) % 96}%; --drift:${(index % 5 - 2) * 22}px; --delay:-${(index * 0.6).toFixed(1)}s; --duration:${(5 + index * 0.25).toFixed(2)}s`}></i>)}
        </div>
        <img class="lock-knock-cover" src={coverHorizontal.src} alt="" />

        <div class="lock-knock-content">
          <p class="work-kicker">01 / GAME PROJECT</p>
          <img class="lock-knock-title" src={titleImage.src} alt="洛克的迷宫" />
          <p class="lock-knock-summary">探索克苏鲁风格的诡异迷宫，躲避恶灵与怪物的追杀。</p>
          <div class="work-tags" aria-label="项目标签">
            <span>Unreal Engine</span>
            <span>探索</span>
            <span>迷宫</span>
            <span>角色扮演</span>
          </div>

        </div>
        <div class="screenshot-carousel" data-screenshot-carousel aria-label="洛克的迷宫游戏截图">
          <div class="screenshot-viewport">
            <div class="screenshot-track" data-screenshot-track>
              <figure class="screenshot-slide is-clone" data-screenshot-slide aria-hidden="true">
                <img src={menuImage.src} alt="" />
              </figure>
              <figure class="screenshot-slide" data-screenshot-slide>
                <img src={lanternCoverImage.src} alt="洛克的迷宫提灯封面画面" />
              </figure>
              <figure class="screenshot-slide" data-screenshot-slide>
                <img src={gameplayImage.src} alt="洛克的迷宫室内探索画面" />
              </figure>
              <figure class="screenshot-slide" data-screenshot-slide>
                <img src={menuImage.src} alt="洛克的迷宫主菜单画面" />
              </figure>
              <figure class="screenshot-slide is-clone" data-screenshot-slide aria-hidden="true">
                <img src={lanternCoverImage.src} alt="" />
              </figure>
            </div>
            <button class="screenshot-side-button is-previous" type="button" data-screenshot-prev aria-label="上一张游戏截图">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m15 18-6-6 6-6" /></svg>
            </button>
            <button class="screenshot-side-button is-next" type="button" data-screenshot-next aria-label="下一张游戏截图">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 18 6-6-6-6" /></svg>
            </button>
          </div>
          <div class="screenshot-pagination" aria-label="游戏截图分页">
            <button class="screenshot-dot" type="button" data-screenshot-dot aria-label="查看第 1 张游戏截图"></button>
            <button class="screenshot-dot" type="button" data-screenshot-dot aria-label="查看第 2 张游戏截图"></button>
            <button class="screenshot-dot" type="button" data-screenshot-dot aria-label="查看第 3 张游戏截图"></button>
          </div>
        </div>
        <img class="lock-knock-poster" src={coverVertical.src} alt="" />
      </article>

      <article class="work-panel seer-panel" data-work-panel data-nav-surface="seer" aria-hidden="true">
        <div class="seer-content">
          <p class="work-kicker">02 / DESKTOP TOOL</p>
          <h3 class="seer-title">{seerAssistant.title}</h3>
          <p class="seer-summary">{seerAssistant.text}</p>
          <div class="work-tags seer-tags" aria-label="项目标签">
            {seerAssistant.tags?.map((tag) => <span>{tag}</span>)}
          </div>
          <a class="seer-link" href={seerAssistant.link} target="_blank" rel="noopener noreferrer">{seerAssistant.linkText || '前往查看'} <span aria-hidden="true">&#8599;</span></a>
        </div>
        <figure class="seer-screenshot">
          <img src={seerAssistantScreenshot.src} alt="赛尔号记牌器软件界面截图" />
        </figure>
      </article>

      {otherWorks.map((item, index) => (
        <article class="work-panel archive-panel" data-work-panel data-nav-surface="ember" aria-hidden="true">
          <span class="archive-orb archive-orb-one" aria-hidden="true"></span>
          <span class="archive-orb archive-orb-two" aria-hidden="true"></span>
          <div class="archive-content">
            <p class="work-kicker">{String(index + 2).padStart(2, '0')} / GAME PROJECT</p>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            {item.link && <a href={item.link} target="_blank" rel="noopener noreferrer">{item.linkText || '前往查看'} <span aria-hidden="true">&#8599;</span></a>}
          </div>
          <p class="archive-index" aria-hidden="true">{String(index + 2).padStart(2, '0')}</p>
        </article>
      ))}
    </div>

    <div class="carousel-ui">
      <p class="carousel-count" aria-live="polite"><span data-current-work>01</span></p>
      <div class="carousel-controls">
        <button type="button" class="carousel-button" data-work-prev aria-label="上一个作品">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m15 18-6-6 6-6" /></svg>
        </button>
        <button type="button" class="carousel-button" data-work-next aria-label="下一个作品">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 18 6-6-6-6" /></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  const carousel = document.querySelector<HTMLElement>('[data-work-carousel]');

  if (carousel) {
    const panels = [...carousel.querySelectorAll<HTMLElement>('[data-work-panel]')];
    const previous = carousel.querySelector<HTMLButtonElement>('[data-work-prev]');
    const next = carousel.querySelector<HTMLButtonElement>('[data-work-next]');
    const currentLabel = carousel.querySelector<HTMLElement>('[data-current-work]');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    let currentIndex = 0;
    let timer: number | undefined;
    let touchStartX = 0;

    const showPanel = (nextIndex: number) => {
      currentIndex = (nextIndex + panels.length) % panels.length;
      panels.forEach((panel, index) => {
        const active = index === currentIndex;
        panel.classList.toggle('is-active', active);
        panel.setAttribute('aria-hidden', String(!active));
      });
      if (currentLabel) currentLabel.textContent = String(currentIndex + 1).padStart(2, '0');
      document.dispatchEvent(new CustomEvent('workchange', { detail: { surface: panels[currentIndex]?.dataset.navSurface ?? 'default' } }));
    };

    const stopAutoplay = () => {
      if (timer) window.clearInterval(timer);
      timer = undefined;
    };

    const startAutoplay = () => {
      stopAutoplay();
      if (!reducedMotion.matches) timer = window.setInterval(() => showPanel(currentIndex + 1), 7000);
    };

    const move = (direction: number) => {
      showPanel(currentIndex + direction);
      startAutoplay();
    };

    previous?.addEventListener('click', () => move(-1));
    next?.addEventListener('click', () => move(1));
    carousel.addEventListener('mouseenter', stopAutoplay);
    carousel.addEventListener('mouseleave', startAutoplay);
    carousel.addEventListener('focusin', stopAutoplay);
    carousel.addEventListener('focusout', (event) => {
      if (!carousel.contains(event.relatedTarget as Node | null)) startAutoplay();
    });
    carousel.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowLeft') {
        event.preventDefault();
        move(-1);
      }
      if (event.key === 'ArrowRight') {
        event.preventDefault();
        move(1);
      }
    });
    carousel.addEventListener('touchstart', (event) => {
      touchStartX = event.changedTouches[0]?.clientX ?? 0;
      stopAutoplay();
    }, { passive: true });
    carousel.addEventListener('touchend', (event) => {
      const distance = (event.changedTouches[0]?.clientX ?? touchStartX) - touchStartX;
      if (Math.abs(distance) > 48) move(distance > 0 ? -1 : 1);
      else startAutoplay();
    }, { passive: true });
    document.addEventListener('visibilitychange', () => document.hidden ? stopAutoplay() : startAutoplay());
    reducedMotion.addEventListener('change', startAutoplay);
    startAutoplay();
  }

  const screenshotCarousel = document.querySelector<HTMLElement>('[data-screenshot-carousel]');

  if (screenshotCarousel) {
    const viewport = screenshotCarousel.querySelector<HTMLElement>('.screenshot-viewport');
    const track = screenshotCarousel.querySelector<HTMLElement>('[data-screenshot-track]');
    const slides = [...screenshotCarousel.querySelectorAll<HTMLElement>('[data-screenshot-slide]')];
    const dots = [...screenshotCarousel.querySelectorAll<HTMLButtonElement>('[data-screenshot-dot]')];
    const previous = screenshotCarousel.querySelector<HTMLButtonElement>('[data-screenshot-prev]');
    const next = screenshotCarousel.querySelector<HTMLButtonElement>('[data-screenshot-next]');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    let currentIndex = 2;
    let isTransitioning = false;

    const positionSlides = (animate = true) => {
      if (!viewport || !track || !slides[currentIndex]) return;
      const currentSlide = slides[currentIndex];
      const offset = viewport.clientWidth / 2 - currentSlide.offsetLeft - currentSlide.clientWidth / 2;
      track.classList.toggle('is-snapping', !animate);
      track.style.transform = `translate3d(${offset}px, 0, 0)`;
      slides.forEach((slide, index) => slide.classList.toggle('is-current', index === currentIndex));
      dots.forEach((dot, index) => {
        const active = index === (currentIndex + 2) % 3;
        dot.classList.toggle('is-active', active);
        dot.setAttribute('aria-current', active ? 'true' : 'false');
      });
    };

    const moveSlides = (direction: number) => {
      if (isTransitioning) return;
      currentIndex += direction;
      if (reducedMotion.matches) {
        if (currentIndex === 0) currentIndex = 3;
        if (currentIndex === slides.length - 1) currentIndex = 1;
        positionSlides(false);
        return;
      }
      isTransitioning = true;
      positionSlides();
    };

    previous?.addEventListener('click', () => moveSlides(-1));
    next?.addEventListener('click', () => moveSlides(1));
    dots.forEach((dot, index) => dot.addEventListener('click', () => {
      if (isTransitioning || currentIndex === index + 1) return;
      currentIndex = index + 1;
      isTransitioning = !reducedMotion.matches;
      positionSlides(reducedMotion.matches === false);
    }));
    track?.addEventListener('transitionend', () => {
      if (currentIndex === 0) {
        currentIndex = 3;
        positionSlides(false);
      } else if (currentIndex === slides.length - 1) {
        currentIndex = 1;
        positionSlides(false);
      }
      isTransitioning = false;
    });
    if (viewport && 'ResizeObserver' in window) new ResizeObserver(() => positionSlides(false)).observe(viewport);
    requestAnimationFrame(() => positionSlides(false));
  }
</script>

<style>
  .works-slide.slide { min-height: 100svh; padding: 0; }
  .work-carousel { position: relative; width: 100%; min-height: 100svh; overflow: hidden; background: #100b09; color: #f7ead7; outline: none; }
  .work-track, .work-panel { min-height: 100svh; }
  .work-panel { position: absolute; inset: 0; visibility: hidden; opacity: 0; transition: opacity 700ms ease, visibility 0s linear 700ms; overflow: hidden; }
  .work-panel.is-active { visibility: visible; opacity: 1; transition: opacity 700ms ease; }
  .lock-knock-cover { position: absolute; inset: 0; width: 100%; height: 100%; }
  .lock-knock-cover { object-fit: cover; object-position: center; filter: saturate(.85) contrast(1.08); transform: scale(1.04); transition: transform 8s ease-out; }
  .is-active .lock-knock-cover { transform: scale(1); }
  .firelight { position: absolute; z-index: 1; width: 65vw; height: 55vw; min-width: 580px; min-height: 480px; left: -12vw; bottom: -38vw; border-radius: 50%; background: radial-gradient(ellipse, rgba(255, 186, 65, .48) 0%, rgba(230, 77, 18, .25) 32%, rgba(122, 20, 6, .1) 55%, transparent 72%); filter: blur(12px); animation: blaze 4.5s ease-in-out infinite alternate; mix-blend-mode: screen; }
  .embers { position: absolute; inset: 0; z-index: 2; pointer-events: none; overflow: hidden; }
  .embers i { position: absolute; width: 3px; height: 3px; left: var(--x); bottom: -2%; border-radius: 50%; background: #ffd278; box-shadow: 0 0 8px #e25618; opacity: 0; animation: ember var(--duration) linear infinite; animation-delay: var(--delay); }
  .lock-knock-content { position: relative; z-index: 3; width: min(44vw, 720px); padding: clamp(130px, 17vh, 190px) 0 90px; margin-left: max(32px, calc((100vw - 1200px) / 2)); }
  .work-kicker { margin-bottom: 24px; color: #e4b36e; font-size: 11px; font-weight: 600; letter-spacing: .22em; }
  .lock-knock-title { width: min(100%, 500px); filter: drop-shadow(0 10px 24px rgba(0, 0, 0, .45)); transform: translateY(18px); opacity: 0; transition: opacity 700ms ease 170ms, transform 700ms ease 170ms; }
  .is-active .lock-knock-title, .is-active .lock-knock-summary, .is-active .work-tags { opacity: 1; transform: none; }
  .lock-knock-summary { max-width: 600px; margin-top: 30px; font-family: var(--font-display); font-size: clamp(22px, 2.3vw, 32px); line-height: 1.25; letter-spacing: -.03em; color: #f4ddba; opacity: 0; transform: translateY(18px); transition: opacity 700ms ease 300ms, transform 700ms ease 300ms; }
  .work-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 28px; opacity: 0; transform: translateY(18px); transition: opacity 700ms ease 420ms, transform 700ms ease 420ms; }
  .work-tags span { padding: 6px 10px; border: 1px solid rgba(233, 184, 113, .45); color: #efd0a0; font-size: 12px; letter-spacing: .08em; }
  .screenshot-carousel { position: absolute; z-index: 4; right: clamp(64px, 8vw, 160px); bottom: clamp(88px, 11vh, 132px); width: clamp(320px, 34vw, 620px); opacity: 0; transform: translateY(18px); transition: opacity 700ms ease 520ms, transform 700ms ease 520ms; }
  .is-active .screenshot-carousel { opacity: 1; transform: none; }
  .screenshot-viewport { position: relative; overflow: hidden; padding: 12px 0; }
  .screenshot-track { display: flex; gap: 18px; transition: transform 480ms cubic-bezier(.22, .7, .2, 1); will-change: transform; }
  .screenshot-track.is-snapping { transition: none; }
  .screenshot-slide { flex: 0 0 76%; aspect-ratio: 16 / 9; margin: 0; overflow: hidden; box-shadow: 0 14px 34px rgba(0, 0, 0, .4); opacity: .48; transform: scale(.94); transition: opacity 480ms ease, transform 480ms ease; }
  .screenshot-slide.is-current { opacity: 1; transform: none; }
  .screenshot-slide img { width: 100%; height: 100%; object-fit: cover; }
  .screenshot-side-button { position: absolute; top: 12px; bottom: 12px; z-index: 1; display: grid; width: 10%; place-items: center; color: #f6d9a8; opacity: 0; pointer-events: none; transition: opacity .2s ease, background .2s ease; }
  .screenshot-side-button.is-previous { left: 0; }
  .screenshot-side-button.is-next { right: 0; }
  .screenshot-side-button svg { width: 24px; fill: none; stroke: currentColor; stroke-width: 1.5; filter: drop-shadow(0 2px 5px rgba(0, 0, 0, .7)); }
  .screenshot-carousel:hover .screenshot-side-button, .screenshot-carousel:focus-within .screenshot-side-button { opacity: 1; pointer-events: auto; }
  .screenshot-side-button:hover, .screenshot-side-button:focus-visible { background: rgba(255, 229, 191, .12); }
  .screenshot-pagination { display: flex; justify-content: center; gap: 9px; margin-top: 10px; }
  .screenshot-dot { width: 7px; height: 7px; border-radius: 50%; background: rgba(246, 217, 168, .38); transition: background .2s ease, transform .2s ease; }
  .screenshot-dot:hover, .screenshot-dot:focus-visible, .screenshot-dot.is-active { background: #f6d9a8; transform: scale(1.25); }
  .lock-knock-poster { display: none; }
  .seer-panel { background: radial-gradient(circle at 88% 18%, rgba(83, 135, 180, .22), transparent 30%), linear-gradient(125deg, #121820, #121a20 52%, #202a2d); }
  .seer-content { position: relative; z-index: 2; width: min(40vw, 580px); padding: clamp(130px, 17vh, 190px) 0 90px; margin-left: max(32px, calc((100vw - 1200px) / 2)); opacity: 0; transform: translateY(20px); transition: opacity 600ms ease 180ms, transform 600ms ease 180ms; }
  .is-active .seer-content { opacity: 1; transform: none; }
  .seer-content .work-kicker { color: #8fc9c3; }
  .seer-title { font-family: var(--font-display); font-size: clamp(48px, 6.4vw, 82px); font-weight: 500; line-height: .98; letter-spacing: -.05em; color: #eaf1ee; }
  .seer-summary { max-width: 520px; margin-top: 28px; color: #c9d5d0; font-size: 16px; line-height: 1.8; }
  .seer-tags { opacity: 1; transform: none; }
  .seer-tags span { border-color: rgba(143, 201, 195, .5); color: #c0e4df; }
  .seer-link { display: inline-block; margin-top: 30px; padding-bottom: 6px; border-bottom: 1px solid currentColor; color: #a9d7d1; font-size: 14px; }
  .seer-screenshot { position: absolute; top: 50%; right: max(48px, calc((100vw - 1200px) / 2)); z-index: 1; width: min(36vw, 500px); height: min(74svh, 820px); margin: 0; transform: translateY(-50%); }
  .seer-screenshot img { width: 100%; height: 100%; object-fit: contain; filter: drop-shadow(0 24px 34px rgba(0, 0, 0, .34)); }
  .carousel-ui { position: absolute; z-index: 8; left: max(32px, calc((100vw - 1200px) / 2)); right: max(32px, calc((100vw - 1200px) / 2)); bottom: 34px; display: flex; align-items: center; justify-content: space-between; }
  .carousel-count { display: flex; align-items: center; gap: 9px; font-size: 12px; letter-spacing: .15em; color: #f2d6a6; }
  .carousel-count i { display: block; width: 44px; height: 1px; background: rgba(242, 214, 166, .55); }
  .carousel-controls { display: flex; gap: 8px; }
  .carousel-button { display: grid; width: 42px; height: 42px; place-items: center; border: 1px solid rgba(246, 217, 168, .5); color: #f6d9a8; transition: color .2s ease, background .2s ease; }
  .carousel-button:hover, .carousel-button:focus-visible { color: #251109; background: #f6d9a8; }
  .carousel-button svg { width: 19px; fill: none; stroke: currentColor; stroke-width: 1.5; }
  .archive-panel { display: flex; align-items: center; background: #18120f; isolation: isolate; }
  .archive-panel::before { content: ''; position: absolute; inset: 0; background: linear-gradient(120deg, #190e08, #2c211a 50%, #110d0b); }
  .archive-orb { position: absolute; border-radius: 50%; filter: blur(4px); opacity: .7; }
  .archive-orb-one { width: 52vw; height: 52vw; left: -18vw; top: -22vw; background: radial-gradient(circle, #a74724, transparent 67%); }
  .archive-orb-two { width: 44vw; height: 44vw; right: -17vw; bottom: -23vw; background: radial-gradient(circle, #72553a, transparent 70%); }
  .archive-content { position: relative; z-index: 1; width: min(720px, 100% - 64px); margin: 0 auto; transform: translateY(20px); opacity: 0; transition: opacity 600ms ease 180ms, transform 600ms ease 180ms; }
  .is-active .archive-content { opacity: 1; transform: none; }
  .archive-content h3 { max-width: 740px; font-family: var(--font-display); font-size: clamp(44px, 7vw, 88px); font-weight: 500; line-height: .98; letter-spacing: -.05em; color: #f1debf; }
  .archive-content > p:not(.work-kicker) { max-width: 520px; margin-top: 28px; color: #cdbda8; font-size: 16px; line-height: 1.8; }
  .archive-content a { display: inline-block; margin-top: 30px; padding-bottom: 6px; border-bottom: 1px solid currentColor; color: #e8ad66; font-size: 14px; }
  .archive-index { position: absolute; right: 6vw; bottom: 11vh; z-index: 1; font-family: var(--font-display); font-size: clamp(160px, 27vw, 420px); line-height: .7; color: rgba(231, 196, 148, .06); }
  @keyframes blaze { to { transform: translate(12%, -10%) scale(1.18); opacity: .8; } }
  @keyframes ember { 0% { transform: translate3d(0, 0, 0) scale(.4); opacity: 0; } 15% { opacity: .9; } 100% { transform: translate3d(var(--drift), -90vh, 0) scale(1.3); opacity: 0; } }
  @media (max-width: 768px) {
    .work-carousel, .work-track, .work-panel { min-height: max(1120px, 100svh); }
    .lock-knock-cover { display: none; }
    .lock-knock-panel { background: linear-gradient(165deg, #250906, #120a08 55%, #2a1007); }
    .lock-knock-poster { display: block; position: absolute; right: -14%; top: 0; width: 78%; height: 100%; object-fit: cover; object-position: center; opacity: .54; mix-blend-mode: screen; }
    .firelight { left: -75vw; bottom: -75vw; min-width: 500px; min-height: 500px; }
    .lock-knock-content { width: min(72%, 380px); padding-top: 145px; margin-left: 24px; }
    .work-kicker { margin-bottom: 18px; }
    .lock-knock-summary { margin-top: 22px; font-size: 23px; }
    .screenshot-carousel { position: relative; right: auto; bottom: auto; width: calc(100vw - 48px); margin: 24px 24px 88px; }
    .seer-content { width: calc(100% - 48px); padding-top: 120px; margin-left: 24px; }
    .seer-title { font-size: clamp(44px, 13vw, 64px); }
    .seer-screenshot { position: relative; top: auto; right: auto; width: min(72vw, 360px); height: auto; margin: 20px auto 88px; transform: none; }
    .seer-screenshot img { height: auto; }
    .carousel-ui { left: 24px; right: 24px; bottom: 24px; }
    .archive-content { width: calc(100% - 48px); }
    .archive-index { right: 0; bottom: 12vh; }
  }
  @media (prefers-reduced-motion: reduce) {
    .work-panel, .lock-knock-cover, .lock-knock-title, .lock-knock-summary, .work-tags, .screenshot-carousel, .screenshot-track, .screenshot-slide, .archive-content { transition: none; }
    .firelight, .embers i { animation: none; }
  }
</style>
