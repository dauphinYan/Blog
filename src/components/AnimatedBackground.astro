<canvas id="animated-lines" class="animated-lines"></canvas>

<style>
  .animated-lines {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 2;
    opacity: 0.3;
  }
</style>

<script>
  class Line {
    x: number;
    y: number;
    length: number;
    angle: number;
    speed: number;
    angularSpeed: number;
    opacity: number;

    constructor(canvas: HTMLCanvasElement) {
      this.x = Math.random() * canvas.width;
      this.y = Math.random() * canvas.height;
      this.length = Math.random() * 80 + 40;
      this.angle = Math.random() * Math.PI * 2;
      this.speed = Math.random() * 0.5 + 0.2;
      this.angularSpeed = (Math.random() - 0.5) * 0.01;
      this.opacity = Math.random() * 0.5 + 0.3;
    }

    update(canvas: HTMLCanvasElement) {
      this.angle += this.angularSpeed;
      this.x += Math.cos(this.angle) * this.speed;
      this.y += Math.sin(this.angle) * this.speed;

      if (this.x < -this.length) this.x = canvas.width + this.length;
      if (this.x > canvas.width + this.length) this.x = -this.length;
      if (this.y < -this.length) this.y = canvas.height + this.length;
      if (this.y > canvas.height + this.length) this.y = -this.length;
    }

    draw(ctx: CanvasRenderingContext2D) {
      const endX = this.x + Math.cos(this.angle) * this.length;
      const endY = this.y + Math.sin(this.angle) * this.length;

      ctx.beginPath();
      ctx.moveTo(this.x, this.y);
      ctx.lineTo(endX, endY);
      ctx.strokeStyle = `rgba(185, 130, 90, ${this.opacity})`;
      ctx.lineWidth = 1;
      ctx.stroke();
    }
  }

  function initAnimation() {
    const canvas = document.getElementById('animated-lines') as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let lines: Line[] = [];
    function resize() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }

    function createLines() {
      const count = Math.floor((canvas.width * canvas.height) / 40000);
      lines = Array.from({ length: Math.min(count, 80) }, () => new Line(canvas));
    }

    function animate() {
      // The guard above guarantees a rendering context for the animation lifetime.
      ctx!.clearRect(0, 0, canvas.width, canvas.height);

      for (const line of lines) {
        line.update(canvas);
        line.draw(ctx!);
      }

      requestAnimationFrame(animate);
    }

    resize();
    createLines();
    animate();

    window.addEventListener('resize', () => {
      resize();
      createLines();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAnimation);
  } else {
    initAnimation();
  }
</script>
