---
import { profile } from '@/content/profile';
import { navSlides } from '@/content/slides';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const avatarSrc = `${base}assets/avatar.jpg`;
const navItems = navSlides.map((slide) => ({ href: `#${slide.id}`, label: slide.navLabel! }));
---

<nav class="top-nav" data-surface="default">
  <div class="nav-container">
    <a href="#welcome" class="nav-brand" aria-label="回到欢迎区域">
      <span class="nav-avatar">
        <img src={avatarSrc} alt="头像" />
      </span>
      <span class="logo-text">{profile.name}</span>
    </a>

    <div class="nav-right">
      <div class="nav-links">
        {navItems.map((item) => <a href={item.href} class="nav-link">{item.label}</a>)}
      </div>
      <button class="theme-toggle" type="button" aria-label="切换深色模式">
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>

    <div class="mobile-right">
      <button class="theme-toggle" type="button" aria-label="切换深色模式">
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
      <button class="mobile-menu-btn" type="button" aria-label="打开导航菜单" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

<div class="mobile-menu" data-surface="default" aria-label="移动端导航">
  {navItems.map((item) => <a href={item.href} class="mobile-link">{item.label}</a>)}
</div>

<script>
  const menuButton = document.querySelector<HTMLButtonElement>('.mobile-menu-btn');
  const mobileMenu = document.querySelector('.mobile-menu');
  const nav = document.querySelector<HTMLElement>('.top-nav');
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-link, .mobile-link');
  const themeToggles = document.querySelectorAll<HTMLButtonElement>('.theme-toggle');
  let activeSlideId = location.hash.slice(1) || 'welcome';

  const updateSurface = (surface = 'default') => {
    nav?.setAttribute('data-surface', surface);
    mobileMenu?.setAttribute('data-surface', surface);
  };

  const closeMenu = () => {
    mobileMenu?.classList.remove('active');
    menuButton?.classList.remove('active');
    menuButton?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };

  menuButton?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('active') ?? false;
    menuButton.classList.toggle('active', isOpen);
    menuButton.setAttribute('aria-expanded', String(isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  navLinks.forEach((link) => {
    link.addEventListener('click', (event) => {
      const href = link.getAttribute('href');
      if (!href?.startsWith('#')) return;

      const target = document.querySelector(href);
      if (!target) return;

      event.preventDefault();
      closeMenu();
       target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

    const pagerDots = document.querySelectorAll<HTMLAnchorElement>('.slide-pager-dot');
    const updateActiveSlide = (id: string) => {
      activeSlideId = id;
      pagerDots.forEach((dot) => dot.classList.toggle('active', dot.dataset.slideId === id));
     navLinks.forEach((link) => {
       const isIntroSlide = ['intro', 'experience', 'current', 'anime', 'dream'].includes(id) && link.getAttribute('href') === '#intro';
        link.classList.toggle('active', link.getAttribute('href') === `#${id}` || isIntroSlide);
      });
      const slide = document.getElementById(id);
      const activeWork = slide?.querySelector<HTMLElement>('[data-work-panel].is-active');
      updateSurface(activeWork?.dataset.navSurface ?? slide?.dataset.navSurface ?? 'default');
    };

   document.addEventListener('slidechange', (event) => {
     updateActiveSlide((event as CustomEvent<{ id: string }>).detail.id);
    });
    updateActiveSlide(location.hash.slice(1) || 'welcome');
    document.addEventListener('workchange', (event) => {
      if (activeSlideId !== 'works') return;
      updateSurface((event as CustomEvent<{ surface: string }>).detail.surface);
    });

  const initTheme = () => {
    const saved = localStorage.getItem('theme');
    if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.setAttribute('data-theme', 'dark');
    }
  };

  const toggleTheme = () => {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    if (isDark) {
      document.documentElement.removeAttribute('data-theme');
      localStorage.setItem('theme', 'light');
    } else {
      document.documentElement.setAttribute('data-theme', 'dark');
      localStorage.setItem('theme', 'dark');
    }
  };

  initTheme();
  themeToggles.forEach((btn) => btn.addEventListener('click', toggleTheme));
</script>
