---
import { profile } from '@/content/profile';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const avatarSrc = `${base}assets/avatar.jpg`;
const navItems = [
  { href: '#welcome', label: '欢迎' },
  { href: '#intro', label: '介绍' },
  { href: '#works', label: '作品' },
  { href: '#contact', label: '联系' },
];
---

<nav class="top-nav">
  <div class="nav-container">
    <a href="#welcome" class="nav-brand" aria-label="回到欢迎区域">
      <span class="nav-avatar">
        <img src={avatarSrc} alt="头像" />
      </span>
      <span class="logo-text">{profile.name}</span>
    </a>

    <div class="nav-right">
      <div class="nav-links">
        {navItems.map((item) => <a href={item.href} class="nav-link">{item.label}</a>)}
      </div>
      <button class="theme-toggle" type="button" aria-label="切换深色模式">
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>

    <div class="mobile-right">
      <button class="theme-toggle" type="button" aria-label="切换深色模式">
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
      <button class="mobile-menu-btn" type="button" aria-label="打开导航菜单" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

<div class="mobile-menu" aria-label="移动端导航">
  {navItems.map((item) => <a href={item.href} class="mobile-link">{item.label}</a>)}
</div>

<script>
  const nav = document.querySelector('.top-nav');
  const menuButton = document.querySelector<HTMLButtonElement>('.mobile-menu-btn');
  const mobileMenu = document.querySelector('.mobile-menu');
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-link, .mobile-link');
  const themeToggles = document.querySelectorAll<HTMLButtonElement>('.theme-toggle');

  const closeMenu = () => {
    mobileMenu?.classList.remove('active');
    menuButton?.classList.remove('active');
    menuButton?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };

  menuButton?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('active') ?? false;
    menuButton.classList.toggle('active', isOpen);
    menuButton.setAttribute('aria-expanded', String(isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  navLinks.forEach((link) => {
    link.addEventListener('click', (event) => {
      const href = link.getAttribute('href');
      if (!href?.startsWith('#')) return;

      const target = document.querySelector(href);
      if (!target) return;

      event.preventDefault();
      closeMenu();
      const offset = nav?.clientHeight ?? 0;
      window.scrollTo({ top: target.getBoundingClientRect().top + window.scrollY - offset, behavior: 'smooth' });
    });
  });

  const sections = document.querySelectorAll<HTMLElement>('section[id]');
  const updateActiveLink = () => {
    const current = [...sections].find((section) => {
      const top = section.offsetTop - 96;
      return window.scrollY >= top && window.scrollY < top + section.offsetHeight;
    });

    navLinks.forEach((link) => {
      link.classList.toggle('active', Boolean(current && link.getAttribute('href') === `#${current.id}`));
    });
  };

  window.addEventListener('scroll', updateActiveLink, { passive: true });
  updateActiveLink();

  const initTheme = () => {
    const saved = localStorage.getItem('theme');
    if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.setAttribute('data-theme', 'dark');
    }
  };

  const toggleTheme = () => {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    if (isDark) {
      document.documentElement.removeAttribute('data-theme');
      localStorage.setItem('theme', 'light');
    } else {
      document.documentElement.setAttribute('data-theme', 'dark');
      localStorage.setItem('theme', 'dark');
    }
  };

  initTheme();
  themeToggles.forEach((btn) => btn.addEventListener('click', toggleTheme));
</script>
