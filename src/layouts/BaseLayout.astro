---
import '../styles/global.css';
import AnimatedBackground from '../components/AnimatedBackground.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="https://github.githubassets.com/favicons/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <AnimatedBackground />
    <slot />
    <script>
      const slides = [...document.querySelectorAll<HTMLElement>('.slide[id]')];
      let activeSlide: HTMLElement | undefined;

      const activateSlide = (nextSlide: HTMLElement) => {
        if (nextSlide === activeSlide) return;

        const direction = activeSlide && nextSlide.offsetTop < activeSlide.offsetTop ? 'backward' : 'forward';

        if (activeSlide) {
          activeSlide.classList.remove('is-active', 'is-entering-forward', 'is-entering-backward');
          activeSlide.classList.add(`is-exiting-${direction}`);
        }

        nextSlide.classList.remove('is-exiting-forward', 'is-exiting-backward', 'is-active');
        nextSlide.classList.add(`is-entering-${direction}`);
        activeSlide = nextSlide;

        requestAnimationFrame(() => {
          if (activeSlide !== nextSlide) return;
          nextSlide.classList.add('is-active');
        });

        document.dispatchEvent(new CustomEvent('slidechange', { detail: { id: nextSlide.id } }));
      };

      const findCenteredSlide = () => {
        const viewportCenter = window.innerHeight / 2;
        return slides.reduce<HTMLElement | undefined>((closest, slide) => {
          if (!closest) return slide;
          const slideCenter = slide.getBoundingClientRect().top + slide.getBoundingClientRect().height / 2;
          const closestCenter = closest.getBoundingClientRect().top + closest.getBoundingClientRect().height / 2;
          return Math.abs(slideCenter - viewportCenter) < Math.abs(closestCenter - viewportCenter) ? slide : closest;
        }, undefined);
      };

      if ('IntersectionObserver' in window && slides.length) {
        const observer = new IntersectionObserver(
          () => {
            const centeredSlide = findCenteredSlide();
            if (centeredSlide) activateSlide(centeredSlide);
          },
          { threshold: [0.5] },
        );

        slides.forEach((slide) => observer.observe(slide));
      } else {
        slides.forEach((slide) => slide.classList.add('is-active'));
      }
    </script>
  </body>
</html>
